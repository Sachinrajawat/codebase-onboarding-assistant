# --- LLM ---
# Pick ONE of the two profiles below.

# Profile A: real OpenAI API
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
# OPENAI_BASE_URL=                       # leave unset for real OpenAI

# Profile B: local Ollama (free, requires `ollama serve` running)
# OPENAI_API_KEY=ollama-local-no-key-needed
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_CHAT_MODEL=qwen2.5-coder:7b
# OPENAI_EMBED_MODEL=nomic-embed-text
# EMBED_DIM=768

# --- Storage ---
MONGODB_URI=mongodb://localhost:27017/codebase-onboarding
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- GitHub (optional for public repos; required for higher rate limits / private later) ---
GITHUB_TOKEN=

# --- Server ---
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# --- Indexing limits (tune to control cost) ---
MAX_FILES_PER_REPO=500
MAX_LINES_PER_REPO=100000
MAX_FILE_SIZE_BYTES=200000
EMBED_BATCH_SIZE=64
CACHE_REINDEX_HOURS=24
