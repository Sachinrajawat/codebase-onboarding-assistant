{
  "name": "codebase-onboarding-assistant-server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for the Codebase Onboarding Assistant — clones a GitHub repo, chunks it with tree-sitter, embeds with OpenAI, stores in Qdrant, serves a RAG chat API.",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext js,json src/index.js",
    "start": "node src/index.js"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@qdrant/js-client-rest": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "mongoose": "^8.8.0",
    "openai": "^4.73.0",
    "simple-git": "^3.27.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
